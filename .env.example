# Automation Hub — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required for AI summarization (pdf_processor.py --op summarize)
# Google Gemini / Generative Language
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-flash

# Optional scraper settings (override CLI defaults)
SCRAPER_DELAY=1.0
SCRAPER_TIMEOUT=15
SCRAPER_RETRIES=3
SCRAPER_USER_AGENT=AutomationHub/1.0

# Default output directory for all entrypoints
OUTPUT_DIR=./output

# Optional PDF settings
PDF_MAX_PAGES=500
PDF_AI_MAX_CHARS=8000

# Logging
LOG_LEVEL=INFO

# Security
REQUIRE_API_KEY=true
ADMIN_API_KEY=replace_with_strong_admin_api_key

# Persistence
APP_DB_PATH=./app.db

# Queue backend (Celery + Redis)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
